doctype html
html(lang="en")
    head
        title QWC - Community & Support
        include includes/head.pug
    body(class="page-with-fixed-navbar")
        div(class="")
            nav(class="navbar site-navbar has-background-white py-5")
                div(class="container is-fluid")
                    include includes/navbar-logo.pug
                    div(class="navbar-menu")
                        div(class="navbar-end")
                            include includes/menu.pug
                div(class="is-hidden navbar-side is-fixed is-top-0 is-bottom-0 is-left-0 has-mw-sm", style="width: 75%; z-index: 9999;")
                    div(class="navbar-backdrop is-fixed is-inset-0 has-background-primary", style="opacity: 90%;")
                    nav(class="navbar is-light is-relative is-flex is-flex-direction-column px-6 py-6 has-background-white", style="width: 100%; height: 100%; overflow-y: auto")
                        include includes/hamburger-logo.pug
                        div
                            div(class="is-flex-direction-column")
                                include includes/menu.pug

            section(class="section", style="background-color: #f9f8f6;")
                div(class="container")
                    style.
                        .community-hero {
                            max-width: 760px;
                            margin: 0 auto 3rem;
                            text-align: center;
                        }
                        .community-kicker {
                            display: inline-block;
                            padding: 0.34rem 0.88rem;
                            border-radius: 999px;
                            background: linear-gradient(135deg, rgba(238, 121, 19, 0.12), rgba(147, 176, 35, 0.16));
                            color: var(--qwc-green);
                            font-size: 0.75rem;
                            font-weight: 700;
                            letter-spacing: 0.1em;
                            text-transform: uppercase;
                            box-shadow: inset 0 0 0 1px rgba(88, 150, 50, 0.14);
                            margin-bottom: 1rem;
                        }
                        .community-title {
                            font-size: 2.4rem;
                            line-height: 1.15;
                            letter-spacing: -0.03em;
                            color: #1f2937;
                            font-weight: 800;
                            margin-bottom: 1rem;
                        }
                        .community-intro {
                            color: #667085;
                            font-size: 1.03rem;
                            line-height: 1.8;
                        }
                        .community-section {
                            margin-top: 3.5rem;
                        }
                        .community-section-head {
                            max-width: 760px;
                            margin-bottom: 1.75rem;
                        }
                        .community-section-title {
                            font-size: 1.75rem;
                            line-height: 1.2;
                            color: #1f2937;
                            font-weight: 800;
                            letter-spacing: -0.02em;
                            margin-bottom: 0.65rem;
                        }
                        .community-section-text {
                            color: #667085;
                            line-height: 1.75;
                            font-size: 0.98rem;
                        }
                        .community-card {
                            background: #ffffff;
                            border: 1px solid #ebe7de;
                            border-radius: 1.2rem;
                            padding: 1.5rem;
                            height: 100%;
                            box-shadow: 0 10px 28px rgba(17, 24, 39, 0.06);
                        }
                        .community-card-link {
                            display: block;
                            text-decoration: none;
                            transition: transform 0.2s ease;
                        }
                        .community-card-link:hover {
                            transform: translateY(-2px);
                        }
                        .community-card-link:hover .community-card {
                            box-shadow: 0 16px 34px rgba(17, 24, 39, 0.1);
                            border-color: rgba(88, 150, 50, 0.18);
                        }
                        .community-card-badge {
                            display: inline-block;
                            padding: 0.3rem 0.72rem;
                            border-radius: 999px;
                            background: #f3f7ea;
                            color: var(--qwc-green);
                            font-size: 0.72rem;
                            font-weight: 700;
                            letter-spacing: 0.08em;
                            text-transform: uppercase;
                            margin-bottom: 0.85rem;
                        }
                        .community-card-title {
                            font-size: 1.15rem;
                            color: #1f2937;
                            font-weight: 800;
                            margin-bottom: 0.55rem;
                            letter-spacing: -0.01em;
                        }
                        .community-card-text {
                            color: #667085;
                            font-size: 0.94rem;
                            line-height: 1.7;
                            margin-bottom: 1rem;
                        }
                        .community-links {
                            display: flex;
                            flex-direction: column;
                            gap: 0.75rem;
                        }
                        .community-link {
                            display: inline-flex;
                            align-items: center;
                            justify-content: space-between;
                            gap: 1rem;
                            width: 100%;
                            padding: 0.9rem 1rem;
                            border-radius: 0.95rem;
                            background: var(--qwc-soft);
                            color: #1f2937;
                            text-decoration: none;
                            box-shadow: inset 0 0 0 1px var(--qwc-line);
                            transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
                        }
                        .community-link:hover {
                            transform: translateY(-1px);
                            background: #eef5e3;
                            box-shadow: inset 0 0 0 1px rgba(88, 150, 50, 0.22), 0 10px 20px rgba(88, 150, 50, 0.08);
                        }
                        .community-link-label {
                            font-weight: 700;
                            color: #1f2937;
                        }
                        .community-link-url {
                            color: var(--qwc-blue-text);
                            font-size: 0.9rem;
                            white-space: nowrap;
                        }
                        .support-panel {
                            background: linear-gradient(135deg, #ffffff 0%, #f8fbf3 100%);
                            border: 1px solid #e7eadf;
                            border-radius: 1.4rem;
                            padding: 2rem;
                            box-shadow: 0 12px 28px rgba(17, 24, 39, 0.06);
                        }
                        .support-list {
                            display: flex;
                            flex-direction: column;
                            gap: 1rem;
                            margin-top: 1.25rem;
                        }
                        .support-item {
                            display: flex;
                            gap: 1rem;
                            align-items: flex-start;
                            padding: 1rem 1.1rem;
                            border-radius: 1rem;
                            background: #ffffff;
                            box-shadow: inset 0 0 0 1px #e8ece0;
                        }
                        .support-item-featured {
                            background: linear-gradient(135deg, rgba(88, 150, 50, 0.1) 0%, rgba(147, 176, 35, 0.08) 100%);
                            box-shadow: inset 0 0 0 1px rgba(88, 150, 50, 0.2), 0 12px 28px rgba(88, 150, 50, 0.08);
                        }
                        .support-dot {
                            width: 0.8rem;
                            height: 0.8rem;
                            border-radius: 999px;
                            margin-top: 0.4rem;
                            flex-shrink: 0;
                            background: linear-gradient(135deg, var(--qwc-orange), var(--qwc-lime));
                        }
                        .support-item-featured .support-dot {
                            width: 0.95rem;
                            height: 0.95rem;
                            background: linear-gradient(135deg, var(--qwc-green), var(--qwc-lime));
                            box-shadow: 0 0 0 6px rgba(147, 176, 35, 0.14);
                        }
                        .support-item-title {
                            font-size: 1rem;
                            color: #1f2937;
                            font-weight: 800;
                            margin-bottom: 0.25rem;
                        }
                        .support-item-featured .support-item-title {
                            color: #2f5a1f;
                        }
                        .support-item-text {
                            color: #667085;
                            line-height: 1.7;
                            font-size: 0.94rem;
                        }
                        .support-item-text a {
                            color: var(--qwc-blue-text);
                            font-weight: 700;
                            text-decoration: none;
                        }
                        @media (max-width: 768px) {
                            .community-title {
                                font-size: 1.9rem;
                            }
                            .community-link {
                                flex-direction: column;
                                align-items: flex-start;
                            }
                            .community-link-url {
                                white-space: normal;
                            }
                        }

                    div(class="community-hero")
                        span(class="community-kicker") Community & Support
                        h1(class="community-title") Join the QWC Community
                        p(class="community-intro") QWC is part of a wider open source geospatial ecosystem. Whether you want to attend conferences, connect with user groups, ask questions in forums, or look for support, there are several active places to start.

                    div(class="community-section", id="conferences")
                        div(class="community-section-head")
                            h2(class="community-section-title") Conferences
                            p(class="community-section-text") Discover events where the QGIS, FOSSGIS, and open geospatial communities meet, present new work, and share practical experience.
                        div(class="columns is-multiline is-variable is-5")
                            div(class="column is-12 is-6-tablet is-3-desktop")
                                a(class="community-card-link", href="https://fossgis-konferenz.de", target="_blank", rel="noopener noreferrer")
                                    div(class="community-card")
                                        h3(class="community-card-title") FOSSGIS-Konferenz
                                        p(class="community-card-text") The main conference for the German-speaking open source GIS community, with practical talks, projects, and networking.
                                        div(class="community-link-url") fossgis-konferenz.de
                            div(class="column is-12 is-6-tablet is-3-desktop")
                                a(class="community-card-link", href="https://foss4g.org", target="_blank", rel="noopener noreferrer")
                                    div(class="community-card")
                                        h3(class="community-card-title") FOSS4G
                                        p(class="community-card-text") The global flagship event for free and open source geospatial software, bringing together users, developers, and organizations.
                                        div(class="community-link-url") foss4g.org
                            div(class="column is-12 is-6-tablet is-3-desktop")
                                a(class="community-card-link", href="https://europe.foss4g.org", target="_blank", rel="noopener noreferrer")
                                    div(class="community-card")
                                        h3(class="community-card-title") FOSS4G Europe
                                        p(class="community-card-text") A European gathering focused on open geospatial collaboration, regional exchange, and community-driven innovation.
                                        div(class="community-link-url") europe.foss4g.org
                            div(class="column is-12 is-6-tablet is-3-desktop")
                                a(class="community-card-link", href="https://www.qgis.org", target="_blank", rel="noopener noreferrer")
                                    div(class="community-card")
                                        h3(class="community-card-title") QGIS User Conference
                                        p(class="community-card-text") A dedicated QGIS event where users and contributors share workflows, releases, case studies, and platform direction.
                                        div(class="community-link-url") www.qgis.org

                    div(class="community-section", id="forums-user-groups")
                        div(class="community-section-head")
                            h2(class="community-section-title") Forums & User Groups
                            p(class="community-section-text") Reach out to the wider QGIS and OSGeo community through discussion spaces and regional user groups in German-speaking regions.
                        div(class="columns is-multiline is-variable is-5")
                            div(class="column is-12 is-5-desktop")
                                div(class="community-card")
                                    h3(class="community-card-title") User Forum
                                    p(class="community-card-text") Community discussion is a great first stop for practical questions, peer exchange, and user-driven support.
                                    div(class="community-links")
                                        a(class="community-link", href="https://discourse.osgeo.org", target="_blank", rel="noopener noreferrer")
                                            span(class="community-link-label") Diskussionsforum deutsch
                                            span(class="community-link-url") discourse.osgeo.org

                            div(class="column is-12 is-7-desktop")
                                div(class="community-card")
                                    h3(class="community-card-title") User Groups
                                    p(class="community-card-text") Regional communities help users share know-how, organize meetups, and support local collaboration around QGIS and related tools.
                                    div(class="community-links")
                                        a(class="community-link", href="https://www.qgis.ch", target="_blank", rel="noopener noreferrer")
                                            span(class="community-link-label") QGIS Anwendergruppe Schweiz
                                            span(class="community-link-url") www.qgis.ch
                                        a(class="community-link", href="https://www.qgis.de", target="_blank", rel="noopener noreferrer")
                                            span(class="community-link-label") QGIS-DE
                                            span(class="community-link-url") www.qgis.de
                                        a(class="community-link", href="https://www.teksi.ch", target="_blank", rel="noopener noreferrer")
                                            span(class="community-link-label") TEKSI
                                            span(class="community-link-url") www.teksi.ch

                    div(class="community-section", id="support")
                        div(class="community-section-head")
                            h2(class="community-section-title") Support
                            p(class="community-section-text") QWC benefits from both community-driven help and commercial service providers. Start with the open community for general questions, and turn to professional partners for project-specific support.
                        div(class="support-panel")
                            h3(class="community-card-title") Support Channels
                            p(class="community-card-text") Choose the support path that best matches your need, from open collaboration to commercial consulting and implementation.
                            div(class="support-list")
                                div(class="support-item")
                                    span(class="support-dot")
                                    div
                                        div(class="support-item-title") Community support
                                        div(class="support-item-text")
                                            | Community support is available on
                                            a(href="https://github.com/qwc-services", target="_blank", rel="noopener noreferrer") GitHub
                                            |  through the open source ecosystem and shared issue discussion.
                                div(class="support-item support-item-featured")
                                    span(class="support-dot")
                                    div
                                        div(class="support-item-title") Commercial support
                                        div(class="support-item-text")
                                            | Commercial support is available from
                                            strong
                                                a(href="https://www.sourcepole.com/", target="_blank", rel="noopener noreferrer") Sourcepole
                                            | ,
                                            strong
                                                a(href="https://oslandia.com/en/", target="_blank", rel="noopener noreferrer") Oslandia
                                            | , and other companies working with the QWC and QGIS ecosystem.

            section(class="section")
                include includes/footer.pug
