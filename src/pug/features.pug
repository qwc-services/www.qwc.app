mixin feature-left(img, alt, title, ...texts)
    div(class="column is-4-desktop is-6-tablet is-12-mobile")
        .capability-card
            .capability-card-image
                img(src=img, alt=alt, width="900", height="560")
            .capability-card-body
                h4.capability-card-title= title
                each text in texts
                    p
                        span.icon
                            i(class="fas fa-check")
                        span= text
                if block
                    block

mixin card-labels(labels)
    .capability-card-labels
        each label in labels
            span.capability-card-label= label

mixin feature-image-left(img, alt, title, text)
    .container
        div(class="is-vcentered columns is-multiline")
            div(class="column is-12 is-7-desktop mb-10 mb-0-desktop")
                div(class="has-mw-xl mr-auto-desktop")
                img(src=img, alt=alt, width="900", height="560")
            div(class="column is-12 is-5-desktop")
                div(class="has-mw-md-desktop mx-auto")
                    h3(class="mb-14 title is-size-3 is-spaced")= title
                    div(class="mb-6 is-flex is-align-items-start")= text
                    if block
                        block

mixin feature-image-right(img, alt, title, text)
    .container
        div(class="is-vcentered columns is-multiline is-align-items-center")
            div(class="column is-12 is-6-desktop mb-10 mb-0-desktop")
                h3(class="mb-14 title is-size-3")= title
                div(class="mb-6 is-flex is-align-items-start")= text
                if block
                    block
            div(class="column is-12 is-6-desktop")
                img(src=img, alt=alt, width="900", height="560")

