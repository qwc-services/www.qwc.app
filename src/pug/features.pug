                                    div(class="showcase-stage")
                                        button(class="showcase-arrow is-left", type="button", data-carousel-target="search-showcase", data-carousel-dir="left", aria-label="Scroll left") ←
                                        div(id="search-showcase", class="showcase-track")
                                            +showcase-shot("images/features/suche-1.png", "Search interface and results", "Unified Search")
                                            +showcase-shot("images/features/datenabfragen-3.png", "Filtered table and map results", "Filtering & Querying")
                                            +showcase-shot("images/features/3d-viewer-und-analyse-funktionen-1.png", "Temporal visualization tools", "Time-Based Views")
                                        button(class="showcase-arrow is-right", type="button", data-carousel-target="search-showcase", data-carousel-dir="right", aria-label="Scroll right") →

                    section(class="capability-section", id="editing-workflows")
                        div(class="container")
                            div(class="map-shell")
                                div(class="map-shell-head")
                                    div(class="map-shell-icon")
                                        i(class="fas fa-pen")
                                    div
                                        h2(class="capability-title") Editing & Workflows
                                        p(class="capability-desc") Move from viewing to action in the same interface with guided editing, validation, and workflow-oriented data handling.

                                div(class="columns is-multiline is-variable is-5 map-mini-grid")
                                    +mini-card("Web Editing", "Edit geometry and attributes directly in the browser on top of robust backend workflows.", [{icon: "fas fa-pen-to-square", text: "Web editing"}, {icon: "fas fa-database", text: "PostGIS"}, {icon: "fas fa-diagram-project", text: "Operational workflows"}])
                                    +mini-card("Guided Forms", "Reduce errors through structured forms that follow project rules and data logic.", [{icon: "fas fa-table-list", text: "Forms"}, {icon: "fas fa-shield-halved", text: "Validation"}, {icon: "fas fa-lock", text: "Constraints"}])
                                    +mini-card("Bulk Operations", "Handle larger volumes of data efficiently through connected table-based workflows.", [{icon: "fas fa-table", text: "Attribute tables"}, {icon: "fas fa-layer-group", text: "Bulk actions"}, {icon: "fas fa-arrows-rotate", text: "Batch updates"}])
                                    +mini-card("Data Exchange", "Move information in and out through common formats that fit everyday GIS tasks.", [{icon: "fas fa-file-csv", text: "CSV"}, {icon: "fas fa-clipboard", text: "Clipboard"}, {icon: "fas fa-file-export", text: "DXF / raster"}])
                                    +mini-card("Complex Workflows", "Adapt the client to domain-specific applications and more advanced editing processes.", [{icon: "fas fa-sitemap", text: "Domain apps"}, {icon: "fas fa-gears", text: "Workflow support"}, {icon: "fas fa-puzzle-piece", text: "Custom logic"}])

                                    div(class="showcase-stage")
                                        button(class="showcase-arrow is-left", type="button", data-carousel-target="editing-showcase", data-carousel-dir="left", aria-label="Scroll left") ←
                                        div(id="editing-showcase", class="showcase-track")
                                            +showcase-shot("images/features/qwc-und-qwc-services-1.png", "Editing in the map interface", "Web Editing")
                                            +showcase-shot("images/features/editieren-erweiterte-funktionen-1.png", "Editing form and geometry tools", "Guided Forms")
                                            +showcase-shot("images/features/datenabfragen-3.png", "Attribute table operations", "Bulk Operations")
                                        button(class="showcase-arrow is-right", type="button", data-carousel-target="editing-showcase", data-carousel-dir="right", aria-label="Scroll right") →

                    section(class="capability-section is-tinted", id="printing-export")
                        div(class="container")
                            div(class="map-shell")
                                div(class="map-shell-head")
                                    div(class="map-shell-icon")
                                        i(class="fas fa-print")
                                    div
                                        h2(class="capability-title") Printing & Export
                                        p(class="capability-desc") Turn browser-based GIS work into polished outputs that are ready for review, reporting, and operational delivery.

                                div(class="columns is-multiline is-variable is-5 map-mini-grid")
                                    +mini-card("PDF Printing", "Generate clean, presentation-ready map outputs from layouts prepared in QGIS.", [{icon: "fas fa-file-pdf", text: "PDF output"}, {icon: "fas fa-print", text: "QGIS layouts"}, {icon: "fas fa-star", text: "Print quality"}])
                                    +mini-card("Batch Reports", "Support repeatable output production for records, reports, and operational series.", [{icon: "fas fa-copy", text: "Batch printing"}, {icon: "fas fa-file-lines", text: "Reporting"}, {icon: "fas fa-list-check", text: "Series output"}])
