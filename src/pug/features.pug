mixin top-category(id, icon, title, desc)
    div(class="column is-4-desktop is-6-tablet is-12-mobile")
        a(
            href="#" + id,
            class="top-category-link",
            style="display:block; height:100%; color:inherit; text-decoration:none;"
        )
            article(
                class="feature-card top-category-card",
                style="height:100%; border:1px solid rgba(220,226,235,0.95); box-shadow:0 18px 40px rgba(17,24,39,0.08); position:relative; overflow:hidden; border-radius:1.6rem; background:#fff; transition:transform .22s ease, box-shadow .22s ease, border-color .22s ease;"
            )
                div(style="height:0.22rem; margin:-1.6rem -1.6rem 1rem; background:linear-gradient(90deg, rgba(88,150,50,0.22), rgba(147,176,35,0.3));")
                div(style="padding:0.1rem 0 0.1rem;")
                    div(class="top-category-head", style="display:flex; align-items:center; gap:1rem; margin-bottom:0.8rem;")
                        div(class="feature-icon-wrap top-category-icon", style="margin-bottom:0; flex:0 0 auto;")
                            i(class=icon)
                        h3(class="feature-link-title", style="display:block; margin:0; font-size:1.55rem; line-height:1.08; font-weight:900; color:#13212f; background:none; box-shadow:none; padding:0; border-radius:0; letter-spacing:-0.03em;")= title
                    p(class="card-desc", style="margin:0; color:#607089; line-height:1.6; font-size:0.88rem;")= desc

mixin mini-card(title, intro, items)
    div(class="column is-4-desktop is-6-tablet is-12-mobile")
        article(class="box map-mini-card")
            h4(class="title is-5 map-mini-card-title")= title
            p(class="map-mini-card-intro")= intro
            div(class="content")
                ul(class="map-mini-card-list")
                    each item in items
                        li
                            span(class="icon map-mini-card-list-icon")
                                i(class=item.icon)
                            span= item.text

mixin showcase-shot(img, alt, title)
    div(class="showcase-slide")
        img(src=img, alt=alt, width="1400", height="900")
        div(class="showcase-caption")= title

doctype html
html(lang="en")
    head
        title QWC - Features 2
        include includes/head.pug
        style.
            body,
            .features-section,
            .features-section .title,
            .features-section .subtitle,
            .features-section p,
            .features-section li,
            .features-section a,
            .features-section button {
                font-family: "DM Sans", sans-serif;
            }
            #core-capabilities .section-eyebrow {
                margin-bottom: 0.95rem;
            }
            #core-capabilities .section-main-title {
                font-size: clamp(2.7rem, 5.2vw, 4.6rem);
                line-height: 0.98;
                letter-spacing: -0.05em;
                font-weight: 900;
                color: #13212f;
                max-width: 13ch;
                margin: 0 auto 1rem;
                text-wrap: balance;
            }
            #core-capabilities .section-intro {
                max-width: 46rem;
                font-size: 1.08rem;
                line-height: 1.8;
                color: #607089;
            }
            .top-category-link:hover .top-category-card,
            .top-category-link:focus .top-category-card {
                transform: translateY(-8px);
                box-shadow: 0 28px 56px rgba(88, 150, 50, 0.12), 0 18px 36px rgba(17, 24, 39, 0.08);
                border-color: rgba(88, 150, 50, 0.28);
                background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(248,252,246,1) 100%);
            }
            .top-category-link:focus-visible {
                outline: none;
            }
            .top-category-card {
                padding: 1.7rem;
                min-height: 0;
                transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease, background .24s ease;
            }
            .top-category-card .top-category-icon {
                width: 3.35rem;
                height: 3.35rem;
                border-radius: 1rem;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: rgba(238, 121, 19, 0.08);
                color: var(--qwc-orange);
                border: 1px solid rgba(238, 121, 19, 0.14);
                font-size: 1.15rem;
            }
            .top-category-card .feature-link-title:hover {
                transform: none;
                box-shadow: none;
                color: #1f2937;
                background: none;
            }
            .top-category-link:hover .top-category-icon,
            .top-category-link:focus .top-category-icon {
                background: rgba(238, 121, 19, 0.12);
                border-color: rgba(238, 121, 19, 0.22);
                transform: scale(1.04);
            }
            .top-category-link:hover .feature-link-title,
            .top-category-link:focus .feature-link-title {
                color: rgb(88, 150, 50);
            }
            .discover-more {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                width: fit-content;
                gap: 0.35rem;
                margin-top: 2.4rem;
                margin-left: auto;
                margin-right: auto;
                color: #6b7d78;
                text-decoration: none;
                transition: transform .2s ease, color .2s ease;
            }
            .discover-more-text {
                margin: 0;
                font-size: 0.88rem;
                font-weight: 600;
                letter-spacing: 0.01em;
            }
            .discover-more-arrow {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 2rem;
                height: 2rem;
                border-radius: 999px;
                border: 1px solid rgba(88, 150, 50, 0.18);
                color: rgb(88, 150, 50);
                background: rgba(88, 150, 50, 0.05);
                font-size: 1rem;
                line-height: 1;
                transition: transform .2s ease, border-color .2s ease, background-color .2s ease;
            }
            .discover-more:hover,
            .discover-more:focus {
                color: rgb(88, 150, 50);
                transform: translateY(2px);
            }
            .discover-more:hover .discover-more-arrow,
            .discover-more:focus .discover-more-arrow {
                border-color: rgba(88, 150, 50, 0.28);
                background: rgba(88, 150, 50, 0.1);
                transform: translateY(2px);
            }
            .discover-more:focus-visible {
                outline: none;
            }
            .map-shell {
                background: #ffffff;
                border-radius: 2.25rem;
                padding: 2.6rem 1.9rem 2.4rem;
                box-shadow: 0 26px 60px rgba(88, 150, 50, 0.1), 0 18px 42px rgba(17, 24, 39, 0.05);
                border: 1px solid rgba(88, 150, 50, 0.1);
            }
            .capability-section {
                padding-top: 5.5rem;
                padding-bottom: 5.5rem;
            }
            .map-shell-head {
                display: flex;
                align-items: flex-start;
                gap: 1rem;
                margin-bottom: 1.7rem;
            }
            .map-shell-icon {
                width: 4.1rem;
                height: 4.1rem;
                border-radius: 1.15rem;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: rgba(238, 121, 19, 0.08);
                color: var(--qwc-orange);
                border: 1px solid rgba(238, 121, 19, 0.14);
                flex-shrink: 0;
                font-size: 1.35rem;
            }
            .map-shell .capability-title {
                margin: 0.15rem 0 0.45rem;
                font-size: clamp(2rem, 3vw, 2.9rem);
                line-height: 1.03;
                letter-spacing: -0.04em;
                color: #13212f;
                font-weight: 900;
            }
            .map-shell .capability-desc {
                margin-bottom: 0;
                max-width: 52rem;
                font-size: 1.08rem;
                line-height: 1.8;
                color: #5f7188;
            }
            .map-mini-grid {
                margin-top: 1.9rem;
                margin-bottom: 2.4rem;
                justify-content: center;
            }
            .map-mini-card {
                background: #ffffff;
                border-radius: 1.45rem;
                padding: 1.3rem 1.2rem 1.15rem;
                min-height: 100%;
                box-shadow: 0 16px 38px rgba(17, 24, 39, 0.06);
                border: 1px solid rgba(88, 150, 50, 0.18);
            }
            .map-mini-card-title {
                margin: 0 0 0.7rem !important;
                color: #11263c;
                font-size: 1.32rem;
                font-weight: 900;
                line-height: 1.1;
                letter-spacing: -0.03em;
                text-wrap: balance;
            }
            .map-mini-card-intro {
                margin: 0;
                color: #5f7188;
                line-height: 1.55;
                font-size: 0.84rem;
            }
            .map-mini-card-list {
                margin: 0.9rem 0 0;
                padding-left: 0 !important;
                margin-left: 0 !important;
                color: #2d4258;
                list-style: none !important;
            }
            .map-mini-card-list li {
                margin-bottom: 0.48rem;
                line-height: 1.55;
                font-size: 0.91rem;
                display: flex !important;
                align-items: flex-start;
                gap: 0.55rem;
                margin-left: 0 !important;
                padding-left: 0 !important;
            }
            .map-mini-card .content ul:not(:last-child) {
                margin-left: 0 !important;
            }
            .map-mini-card-list-icon {
                color: var(--qwc-orange);
                margin-top: 0.08rem;
                flex: 0 0 auto;
            }
            .showcase-stage {
                position: relative;
                margin-top: 0.35rem;
            }
            .showcase-arrow {
                position: absolute;
                top: 50%;
                transform: translateY(-50%);
                width: 2.8rem;
                height: 2.8rem;
                border: 0;
                border-radius: 999px;
                background: #ffffff;
                color: #1f2937;
                box-shadow: 0 16px 34px rgba(17, 24, 39, 0.16);
                cursor: pointer;
                font-size: 1rem;
                transition: transform .18s ease, box-shadow .18s ease, background-color .18s ease, color .18s ease;
                z-index: 3;
            }
            .showcase-arrow:hover {
                transform: translateY(calc(-50% - 2px));
                box-shadow: 0 20px 40px rgba(17, 24, 39, 0.2);
                background: #ffffff;
                color: rgb(88, 150, 50);
            }
            .showcase-arrow.is-left {
                left: -0.85rem;
            }
            .showcase-arrow.is-right {
                right: -0.85rem;
            }
            .showcase-track {
                display: flex;
                gap: 1.4rem;
                overflow-x: auto;
                scroll-behavior: smooth;
                padding: 0.35rem 0 0.5rem;
            }
            .showcase-slide {
                position: relative;
                flex: 0 0 min(38rem, 82vw);
                border-radius: 1.8rem;
                overflow: hidden;
                background: #eaeff3;
                box-shadow: 0 24px 54px rgba(17, 24, 39, 0.16);
            }
            .showcase-slide img {
                display: block;
                width: 100%;
                height: 21rem;
                object-fit: cover;
                object-position: center;
            }
            .showcase-caption {
                position: absolute;
                left: 1rem;
                bottom: 1rem;
                display: inline-flex;
                align-items: center;
                max-width: calc(100% - 2rem);
                padding: 0.5rem 0.75rem;
                border-radius: 999px;
                background: rgba(88, 150, 50, 0.76);
                border: 1px solid rgba(88, 150, 50, 0.22);
                box-shadow: 0 10px 22px rgba(88, 150, 50, 0.18);
                color: #ffffff;
                font-size: 0.74rem;
                font-weight: 700;
                letter-spacing: -0.01em;
                line-height: 1.1;
                backdrop-filter: blur(10px);
            }
            .coming-soon-shell {
                background: rgba(255,255,255,0.72);
                border-radius: 1.6rem;
                padding: 1.4rem 1.2rem;
                box-shadow: inset 0 0 0 1px rgba(226, 230, 236, 0.9);
            }
            .coming-soon-shell h3 {
                margin: 0 0 0.35rem;
                color: #1f2937;
                font-size: 1.1rem;
                font-weight: 800;
            }
            .coming-soon-shell p {
                margin: 0;
                color: #607089;
                line-height: 1.65;
            }
            @media (max-width: 768px) {
                #core-capabilities .section-main-title {
                    font-size: 2.35rem;
                    line-height: 1.02;
                    max-width: 11ch;
                }
                .capability-section {
                    padding-top: 4rem;
                    padding-bottom: 4rem;
                }
                .map-shell {
                    padding: 1.5rem 1rem 1.4rem;
                    border-radius: 1.6rem;
                }
                .map-shell-head {
                    align-items: flex-start;
                }
                .showcase-arrow {
                    position: static;
                    transform: none;
                }
                .showcase-arrow:hover {
                    transform: translateY(-2px);
                }
                .showcase-controls {
                    display: flex;
                    gap: 0.7rem;
                }
                .showcase-slide img {
                    height: 15rem;
                }
            }

    body(class="page-with-fixed-navbar")
        div
            nav(class="navbar site-navbar has-background-white py-5")
                div(class="container is-fluid")
                    include includes/navbar-logo.pug
                    div(class="navbar-menu")
                        div(class="navbar-end")
                            include includes/menu.pug
                div(class="is-hidden navbar-side is-fixed is-top-0 is-bottom-0 is-left-0 has-mw-sm", style="width: 75%; z-index: 9999;")
                    div(class="navbar-backdrop is-fixed is-inset-0 has-background-primary", style="opacity: 90%;")
                    nav(class="navbar is-light is-relative is-flex is-flex-direction-column px-6 py-6 has-background-white", style="width: 100%; height: 100%; overflow-y: auto")
                        include includes/hamburger-logo.pug
                        div
                            div(class="is-flex-direction-column")
                                include includes/menu.pug

            section(class="section")
                div(class="container")
                    section(class="features-section", id="core-capabilities")
                        div(class="container")
                            div(class="has-text-centered", style="padding-top: 2rem; padding-bottom: 1.5rem;")
                                h1(class="section-main-title") Key Features

                            div(class="columns is-multiline is-variable is-5", style="margin-top: 3.75rem; margin-bottom: 3.5rem;")
                                +top-category("map-interaction", "fas fa-map-marked-alt", "Map Interaction", "Explore maps with dynamic layers, feature context, and responsive tools.")
                                +top-category("search-analysis", "fas fa-search", "Search & Analysis", "Find the right data quickly and turn it into useful insight.")
                                +top-category("editing-workflows", "fas fa-pen", "Editing & Workflows", "Move from viewing to action with guided, browser-based workflows.")
                                +top-category("printing-export", "fas fa-print", "Printing & Export", "Create polished outputs for delivery, reporting, and review.")
                                +top-category("users-permissions", "fas fa-user-shield", "Users & Permissions", "Control access securely across maps, layers, tools, and services.")
                                +top-category("advanced-capabilities", "fas fa-rocket", "Advanced Capabilities", "Extend the platform with more specialized GIS workflows.")
                            a(class="discover-more", href="#map-interaction")
                                p(class="discover-more-text") Discover more
                                span(class="discover-more-arrow", aria-hidden="true") ↓

                    section(class="capability-section", id="map-interaction")
                        div(class="container")
                            div(class="map-shell")
                                div(class="map-shell-head")
                                    div(class="map-shell-icon")
                                        i(class="fas fa-map-marked-alt")
                                    div
                                        h2(class="capability-title") Map Interaction
                                        p(class="capability-desc") Everything users need to understand spatial data quickly in the browser, from map context to feature detail and on-map interaction.

                                div(class="columns is-multiline is-variable is-5 map-mini-grid")
                                    +mini-card("Dynamic Layers", "Explore spatial content with clear map context and live layer visibility.", [{icon: "fas fa-layer-group", text: "Dynamic layers"}, {icon: "fas fa-list", text: "Legend"}, {icon: "fas fa-map", text: "Map context"}])
                                    +mini-card("Feature Inspection", "Inspect selected data directly in the interface without breaking the workflow.", [{icon: "fas fa-circle-info", text: "Feature info"}, {icon: "fas fa-table", text: "Attribute tables"}, {icon: "fas fa-magnifying-glass", text: "Data inspection"}])
                                    +mini-card("Drawing Tools", "Work directly on top of the map with practical tools for review and markup.", [{icon: "fas fa-ruler", text: "Measurement"}, {icon: "fas fa-pen-ruler", text: "Drawing"}, {icon: "fas fa-pencil", text: "Redlining"}])
                                    +mini-card("Layer Comparison", "Compare content and bring in external services such as WMS, WFS, and similar standards.", [{icon: "fas fa-code-compare", text: "Layer comparison"}, {icon: "fas fa-plug", text: "WMS / WFS"}, {icon: "fas fa-globe", text: "External services"}])
                                    +mini-card("Responsive Design", "Keep the same core experience across larger screens, tablets, and phones.", [{icon: "fas fa-desktop", text: "Desktop"}, {icon: "fas fa-tablet-screen-button", text: "Tablet"}, {icon: "fas fa-mobile-screen-button", text: "Mobile"}])

                                    div(class="showcase-stage")
                                        button(class="showcase-arrow is-left", type="button", data-carousel-target="map-showcase", data-carousel-dir="left", aria-label="Scroll left") ←
                                        div(id="map-showcase", class="showcase-track")
                                            +showcase-shot("images/features/qwc-und-qwc-services-1.png", "Layer tree and live legend", "Layers & Legend")
                                            +showcase-shot("images/features/datenabfragen-1.png", "Feature details and map context", "Feature Information")
                                            +showcase-shot("images/features/mess-und-zeichnungswerkzeuge-1.png", "Drawing and measuring tools", "Drawing & Measuring")
                                        button(class="showcase-arrow is-right", type="button", data-carousel-target="map-showcase", data-carousel-dir="right", aria-label="Scroll right") →

                    section(class="capability-section is-tinted", id="search-analysis")
                        div(class="container")
                            div(class="map-shell")
                                div(class="map-shell-head")
                                    div(class="map-shell-icon")
                                        i(class="fas fa-search")
                                    div
                                        h2(class="capability-title") Search & Analysis
                                        p(class="capability-desc") Help users move from question to answer with less friction, whether they are searching by text, attributes, or spatial context.

                                div(class="columns is-multiline is-variable is-5 map-mini-grid")
                                    +mini-card("Unified Search", "Find relevant places, records, and objects quickly across different data sources.", [{icon: "fas fa-font", text: "Full-text search"}, {icon: "fas fa-filter", text: "Attribute search"}, {icon: "fas fa-bolt", text: "Fast discovery"}])
                                    +mini-card("Search Providers", "Connect internal and external providers so search works for real operational contexts.", [{icon: "fas fa-location-dot", text: "Geocoding"}, {icon: "fas fa-plug", text: "External providers"}, {icon: "fas fa-sliders", text: "Flexible setup"}])
