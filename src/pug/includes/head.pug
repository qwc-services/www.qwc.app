meta(charset="utf-8")
meta(name="viewport", content="width=device-width, initial-scale=1, shrink-to-fit=no")
link(rel="stylesheet", href="https://fonts.googleapis.com/css?family=Inter:400&subset=latin")
link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap")
link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;700&display=swap")
link(rel="stylesheet", href="css/bulma/bulma.min.css")
link(rel="icon", type="image/vnd.microsoft.icon", href="images/favicon.ico")
style.
    :root {
        --qwc-blue-text: #2b6c8f;
        --qwc-green-deep: #447528;
        --qwc-green: #589632;
        --qwc-lime: #93b023;
        //--qwc-line: #d5e6c7;
        --qwc-line: #dfe7cb;
        --qwc-orange: #ee7913;
        --qwc-soft-2: #e4f0d6;
        //--qwc-soft: #eef6e7;
        --qwc-soft: #f7f8f2;
    }
    html {
        scrollbar-color: var(--qwc-orange) #f3efe8;
        scrollbar-width: thin;
    }
    ::-webkit-scrollbar {
        width: 12px;
        height: 12px;
    }
    ::-webkit-scrollbar-track {
        background: #f3efe8;
    }
    ::-webkit-scrollbar-thumb {
        background: var(--qwc-orange);
        border-radius: 999px;
        border: 2px solid #f3efe8;
    }
    ::-webkit-scrollbar-thumb:hover {
        background: #d86d11;
    }
    .site-navbar {
        position: sticky;
        top: 0;
        z-index: 1000;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
    .page-with-fixed-navbar {
        padding-top: 6.25rem;
    }
    .page-with-fixed-navbar .site-navbar.has-background-white {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
    }
    .site-navbar.has-background-white {
        background-color: rgba(255, 255, 255, 0.94) !important;
        box-shadow: 0 8px 24px rgba(17, 24, 39, 0.06);
    }
    .site-navbar.has-background-transparent {
        background-color: rgba(249, 248, 246, 0.9) !important;
        box-shadow: 0 8px 24px rgba(17, 24, 39, 0.06);
    }
    .site-navbar .navbar-end {
        align-items: center;
        gap: 0.15rem;
    }
    .site-navbar .navbar-item,
    .site-navbar .navbar-link {
        color: #1f2937;
        font-weight: 600;
        border-radius: 0.8rem;
    }
    .site-navbar .navbar-item:hover,
    .site-navbar .navbar-link:hover,
    .site-navbar .navbar-item.has-dropdown:hover > .navbar-link {
        color: var(--qwc-green);
        background: transparent;
    }
    .site-navbar .navbar-link:not(.is-arrowless)::after {
        border-color: var(--qwc-lime);
        margin-top: -0.35em;
    }
    .site-navbar .navbar-item.has-dropdown {
        position: relative;
    }
    .site-navbar .navbar-dropdown {
        border: 0;
        border-radius: 0;
        border-top: none;
        min-width: 16rem;
        padding: 0.65rem 0;
        margin-top: 0;
        top: calc(100% - 2px);
        background: #ffffff;
        box-shadow: 0 20px 40px rgba(17, 24, 39, 0.12);
    }
    .site-navbar .navbar-item.has-dropdown:hover .navbar-dropdown {
        display: block;
    }
    .site-navbar .navbar-dropdown .navbar-item {
        padding: 0.85rem 1.5rem;
        color: #111827;
        font-weight: 500;
        white-space: nowrap;
    }
    .site-navbar .navbar-dropdown .navbar-item:hover {
        background: #ffffff;
        color: var(--qwc-green);
    }
    .site-navbar .navbar-dropdown .navbar-item[href^="http"]::after {
        content: "↗";
        margin-left: 0.5rem;
        font-size: 0.8em;
        color: #9ca3af;
    }
    @media (max-width: 1023px) {
        .site-navbar .navbar-end {
            gap: 0;
        }
        .site-navbar .navbar-item,
        .site-navbar .navbar-link {
            border-radius: 0;
        }
        .site-navbar .navbar-dropdown {
            min-width: auto;
            margin-top: 0;
            box-shadow: none;
            padding: 0.2rem 0 0.7rem 0.8rem;
            background: transparent;
        }
        .site-navbar .navbar-dropdown .navbar-item {
            padding: 0.55rem 0.75rem;
            white-space: normal;
        }
    }
script(src="js/main.js")
