doctype html
html(lang="en")
    head
        title QWC - Customization & Extensibility
        include includes/head.pug
    body(class="page-with-fixed-navbar")
        div(class="")
            nav(class="navbar site-navbar has-background-white py-5")
                div(class="container is-fluid")
                    include includes/navbar-logo.pug
                    div(class="navbar-menu")
                        div(class="navbar-end")
                            include includes/menu.pug
                div(class="is-hidden navbar-side is-fixed is-top-0 is-bottom-0 is-left-0 has-mw-sm", style="width: 75%; z-index: 9999;")
                    div(class="navbar-backdrop is-fixed is-inset-0 has-background-primary", style="opacity: 90%;")
                    nav(class="navbar is-light is-relative is-flex is-flex-direction-column px-6 py-6 has-background-white", style="width: 100%; height: 100%; overflow-y: auto")
                        include includes/hamburger-logo.pug
                        div
                            div(class="is-flex-direction-column")
                                include includes/menu.pug

            section(class="section", style="background-color: #f9f8f6;")
                div(class="container")
                    style.
                        :root {
                            --qwc-orange: #ee7913;
                            --qwc-green: #589632;
                            --qwc-lime: #93b023;
                            --qwc-soft: #f7f8f2;
                            --qwc-line: #dfe7cb;
                        }
                        .custom-hero {
                            max-width: 800px;
                            margin: 0 auto 3rem;
                            text-align: center;
                        }
                        .custom-kicker {
                            display: inline-block;
                            padding: 0.34rem 0.88rem;
                            border-radius: 999px;
                            background: linear-gradient(135deg, rgba(238, 121, 19, 0.12), rgba(147, 176, 35, 0.16));
                            color: var(--qwc-green);
                            font-size: 0.75rem;
                            font-weight: 700;
                            letter-spacing: 0.1em;
                            text-transform: uppercase;
                            box-shadow: inset 0 0 0 1px rgba(88, 150, 50, 0.14);
                            margin-bottom: 1rem;
                        }
                        .custom-title {
                            font-size: 2.6rem;
                            line-height: 1.12;
                            letter-spacing: -0.03em;
                            color: #1f2937;
                            font-weight: 800;
                            margin-bottom: 1rem;
                        }
                        .custom-subtitle {
                            max-width: 720px;
                            margin: 0 auto;
                            color: #667085;
                            font-size: 1.05rem;
                            line-height: 1.8;
                        }
                        .custom-grid {
                            margin-top: 3rem;
                        }
                        .custom-card {
                            background: #ffffff;
                            border: 1px solid #ebe7de;
                            border-radius: 1.35rem;
                            padding: 1.7rem;
                            height: 100%;
                            box-shadow: 0 12px 28px rgba(17, 24, 39, 0.06);
                        }
                        .custom-card-badge {
                            display: inline-block;
                            padding: 0.32rem 0.76rem;
                            border-radius: 999px;
                            background: linear-gradient(135deg, rgba(238, 121, 19, 0.08), rgba(147, 176, 35, 0.12));
                            color: var(--qwc-green);
                            font-size: 0.72rem;
                            font-weight: 700;
                            letter-spacing: 0.08em;
                            text-transform: uppercase;
                            margin-bottom: 0.9rem;
                        }
                        .custom-card-title {
                            font-size: 1.28rem;
                            font-weight: 800;
                            color: #1f2937;
                            line-height: 1.25;
                            letter-spacing: -0.02em;
                            margin-bottom: 0.7rem;
                        }
                        .custom-card-text {
                            color: #667085;
                            font-size: 0.95rem;
                            line-height: 1.72;
                            margin-bottom: 1rem;
                        }
                        .custom-points {
                            margin: 0;
                            padding-left: 1.05rem;
                            color: #43515d;
                            list-style: disc;
                        }
                        .custom-points li {
                            margin-bottom: 0.55rem;
                            line-height: 1.6;
                        }
                        .custom-value {
                            margin-top: 3rem;
                            background: linear-gradient(135deg, #ffffff 0%, #f6faef 100%);
                            border: 1px solid #e6eadc;
                            border-radius: 1.45rem;
                            padding: 2rem 2.2rem;
                            box-shadow: 0 14px 30px rgba(17, 24, 39, 0.05);
                        }
                        .custom-value-title {
                            font-size: 1.35rem;
                            font-weight: 800;
                            color: #1f2937;
                            margin-bottom: 0.8rem;
                            letter-spacing: -0.02em;
                        }
                        .custom-value-text {
                            color: #667085;
                            font-size: 1rem;
                            line-height: 1.8;
                        }
                        .custom-microcopy {
                            margin-top: 2rem;
                            padding-top: 1.5rem;
                            border-top: 1px solid rgba(88, 150, 50, 0.14);
                        }
                        .custom-microcopy-title {
                            font-size: 0.9rem;
                            font-weight: 800;
                            color: #355626;
                            letter-spacing: 0.08em;
                            text-transform: uppercase;
                            margin-bottom: 0.9rem;
                        }
                        .custom-chip-list {
                            display: flex;
                            flex-wrap: wrap;
                            gap: 0.7rem;
                        }
                        .custom-chip {
                            display: inline-flex;
                            align-items: center;
                            padding: 0.55rem 0.85rem;
                            border-radius: 999px;
                            background: #ffffff;
                            box-shadow: inset 0 0 0 1px rgba(88, 150, 50, 0.14);
                            color: #355626;
                            font-size: 0.9rem;
                            font-weight: 700;
                        }
                        .case-studies-grid {
                            margin-top: 2rem;
                        }
                        .case-study-card {
                            background: linear-gradient(180deg, #ffffff 0%, #fbfaf7 100%);
                            border: 1px solid #ebe7de;
                            border-radius: 1.45rem;
                            overflow: hidden;
                            box-shadow: 0 16px 34px rgba(17, 24, 39, 0.07);
                            height: 100%;
                        }
                        .case-study-image {
                            background: #edf3ef;
                            padding: 1.2rem;
                            border-bottom: 1px solid #ece7dd;
                        }
                        .case-study-image img {
                            display: block;
                            width: 100%;
                            height: 420px;
                            object-fit: contain;
                            object-position: center;
                            border-radius: 1rem;
                            background: #ffffff;
                        }
                        .case-study-body {
                            padding: 1.5rem 1.55rem 1.6rem;
                        }
                        .case-study-meta {
                            display: inline-flex;
                            align-items: center;
                            padding: 0.34rem 0.76rem;
                            border-radius: 999px;
                            background: linear-gradient(135deg, rgba(238, 121, 19, 0.08), rgba(147, 176, 35, 0.12));
                            color: var(--qwc-green);
                            font-size: 0.72rem;
                            font-weight: 700;
                            letter-spacing: 0.08em;
                            text-transform: uppercase;
                            margin-bottom: 0.9rem;
                        }
                        .case-study-title {
                            font-size: 1.3rem;
                            line-height: 1.25;
                            letter-spacing: -0.02em;
                            color: #1f2937;
                            font-weight: 800;
                            margin-bottom: 0.75rem;
                        }
                        .case-study-text {
                            color: #667085;
                            font-size: 0.96rem;
                            line-height: 1.72;
                            margin-bottom: 1rem;
                        }
                        .case-study-points {
                            margin: 0;
                            padding-left: 1rem;
                            color: #43515d;
                        }
                        .case-study-points li {
                            margin-bottom: 0.5rem;
                            line-height: 1.6;
                        }
                        @media (max-width: 768px) {
                            .custom-title {
                                font-size: 2rem;
                            }
                            .custom-value {
                                padding: 1.5rem;
                            }
                            .case-study-image img {
                                height: 260px;
                            }
                        }

                    div(class="custom-hero")
                        span(class="custom-kicker") Customization & Extensibility
                        h1(class="custom-title") A GIS Platform You Can Shape, Extend, and Keep Evolving
                        p(class="custom-subtitle") QWC is designed as a platform rather than a fixed application. It can be adapted to local workflows, integrated with existing systems, and extended over time without forcing every client into the same interface or release path.

                    div(class="columns is-multiline is-variable is-5 custom-grid", id="what-you-can-build")
                        div(class="column is-12 is-6-desktop")
                            div(class="custom-card")
                                span(class="custom-card-badge") Customization
                                h2(class="custom-card-title") Tailor the interface to real user workflows
                                p(class="custom-card-text") Adapt tools, menus, and views to the workflows users actually need.
                                ul(class="custom-points")
                                    li Role-based interface setup
                                    li Custom styling and forms
                                    li Task-focused user experience

                        div(class="column is-12 is-6-desktop")
                            div(class="custom-card")
                                span(class="custom-card-badge") Extensibility
                                h2(class="custom-card-title") Add new functionality without rebuilding the platform
                                p(class="custom-card-text") Extend QWC with plugins and custom tools while keeping the core stable.
                                ul(class="custom-points")
                                    li Plugin-based extensions
                                    li Project-specific tools
                                    li Maintainable custom logic

                        div(class="column is-12 is-6-desktop")
                            div(class="custom-card")
                                span(class="custom-card-badge") Integration
                                h2(class="custom-card-title") Connect QWC to the systems already in use
                                p(class="custom-card-text") Connect the client to existing services, APIs, and enterprise systems.
                                ul(class="custom-points")
                                    li Standards-based services
                                    li Existing auth and data reuse
                                    li API-driven integration

                        div(class="column is-12 is-6-desktop")
                            div(class="custom-card")
                                span(class="custom-card-badge") Scalability / Future-proofing
                                h2(class="custom-card-title") Build for today’s project and tomorrow’s requirements
                                p(class="custom-card-text") Start focused and expand over time without replacing the platform.
                                ul(class="custom-points")
                                    li Modular growth path
                                    li Structured configuration
                                    li Open standards foundation

                    div(class="custom-value", id="case-studies")
                        h2(class="custom-value-title") Case Studies
                        p(class="custom-value-text") These examples show how QWC can support both focused technical workflows and complex municipal deployments without forcing the same interface on every project.
                        div(class="columns is-multiline is-variable is-5 case-studies-grid")
                            div(class="column is-12")
                                div(class="case-study-card")
                                    div(class="case-study-image")
                                        img(src="images/case-studies/fixpunkte-fpds2-1.png", alt="Fixpunkte FPDS2 case study screenshot")
                                    div(class="case-study-body")
                                        span(class="case-study-meta") Surveying Workflow
                                        h3(class="case-study-title") Fixpunkte - FPDS2
                                        p(class="case-study-text") A specialized technical viewer for Swiss fixed-point data, built to support precise access to reference information through a focused and efficient interface.
                                        ul(class="case-study-points")
                                            li Tailored to a domain-specific workflow instead of a generic public map portal.
                                            li Presents structured geospatial information clearly for expert users.
                                            li Shows how QWC can be shaped into a focused professional application.
                            div(class="column is-12")
                                div(class="case-study-card")
                                    div(class="case-study-image")
                                        img(src="images/case-studies/planas-stadt-frankfurt-1.png", alt="PlanAS Stadt Frankfurt case study screenshot")
                                    div(class="case-study-body")
                                        span(class="case-study-meta") Municipal Platform
                                        h3(class="case-study-title") PlanAS Stadt Frankfurt
                                        p(class="case-study-text") A city-scale planning and urban information platform that demonstrates how QWC can support a richer municipal deployment with tailored content and specialized map tools.
                                        ul(class="case-study-points")
                                            li Organizes planning information in a way that fits municipal processes and public-sector needs.
                                            li Combines custom presentation, workflow orientation, and project-specific functionality.
                                            li Illustrates how the same platform can scale from narrow use cases to broader city deployments.

            section(class="section")
                include includes/footer.pug
