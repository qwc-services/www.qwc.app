doctype html
html(lang="en")
    head
        title QWC - QGIS Webclient
        include includes/head.pug
    body
        div(class="")
            nav(class="navbar site-navbar has-background-transparent py-5 is-relative")
                div(class="container is-fluid")
                    include includes/navbar-logo.pug
                    div(class="navbar-menu")
                        div(class="navbar-end")
                            include includes/menu.pug

            section(class="hero-qwc")
                div(class="hero-glow-top")
                div(class="hero-glow-bottom")

                div(class="section hero-qwc-section")
                    div(class="container hero-qwc-container")
                        div(class="hero-qwc-columns is-vcentered columns is-multiline is-variable is-8")
                            div(class="column is-12 is-7-desktop mb-20 mb-0-desktop")
                                div(class="hero-copy has-mw-md-desktop")
                                    h1(class="title hero-title mb-5")
                                        | QGIS Web Client

                                    p(class="subtitle hero-subtitle mb-5")
                                        | Modern Web GIS, built on QGIS

                                    div(class="buttons hero-buttons")
                                        a(class="button is-primary is-medium is-rounded hero-button-primary", href="features.html") Explore Features
                                        a(class="button is-light is-medium is-rounded hero-button-secondary hero-button-demo", href="https://qwc2.sourcepole.ch") Open Demo

                            div(class="column is-12 is-5-desktop")
                                div(class="hero-visual-wrap")
                                    img(class="image is-fullwidth", src="images/screens-responsive.png", alt="QWC web map interface")
                            //-
                                div(class="column is-12 is-5-desktop")
                                    div(class="hero-visual-wrap")
                                        div(class="hero-shadow")
                                        div(class="hero-card")
                                            div(class="hero-card-topbar")
                                                div(class="hero-card-dots")
                                                    span
                                                    span
                                                    span
                                                div(class="hero-card-label") QWC Map Viewer

                                            div(class="hero-image-wrap")
                                                img(class="image is-fullwidth", src="images/screens-responsive.png", alt="QWC web map interface")

                div(class="is-hidden navbar-side is-fixed is-top-0 is-bottom-0 is-left-0 has-mw-sm", style="width: 75%; z-index: 9999;")
                    div(class="navbar-backdrop is-fixed is-inset-0 has-background-primary", style="opacity: 90%;")
                    nav(class="navbar is-light is-relative is-flex is-flex-direction-column px-6 py-6 has-background-white", style="width: 100%; height: 100%; overflow-y: auto")
                        include includes/hamburger-logo.pug
                        div
                            div(class="is-flex-direction-column")
                                include includes/menu.pug

            section(class="section")
                div(class="container")
                    div(class="columns is-multiline is-variable is-6")
                        div(class="column is-12 is-5-desktop mb-10 mb-0-desktop")
                            div(class="has-mw-md-desktop")
                                span(class="tag is-warning") Why QWC
                                h3(class="my-6 title is-size-3 is-spaced") Built for modern web GIS
                                p(class="has-mw-sm-desktop subtitle")
                                    | QWC is an open source web GIS platform built on the QGIS ecosystem, combining usability, extensibility and modern web technologies.

                        div(class="column is-12 is-7-desktop")
                            div(class="columns is-multiline")
                                div(class="column is-12 is-6-desktop mb-10")
                                    span
                                        svg(xmlns="http://www.w3.org/2000/svg", width="48", height="48", viewbox="0 0 48 48", fill="none")
                                            path(d="M14 40H40", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
