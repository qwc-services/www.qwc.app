            section(class="section")
                div(class="container")
                    div(class="is-vcentered columns is-multiline is-variable is-6")
                        div(class="column is-12 is-7-desktop mb-10 mb-0-desktop")
                            div(class="has-mw-md-desktop is-relative")
                                img(class="is-absolute is-block-widescreen is-hidden-touch is-bottom-0 is-left-0", style="width: 160px; height: 160px; margin-left: -80px; z-index: 1;", src="cronos-assets/elements/light-squares.svg", alt="")
                                img(class="ml-20 is-absolute is-block-widescreen is-hidden-touch is-top-0 is-right-0", style="width: 160px; height: 160px; margin-right: -80px; z-index: 1;", src="cronos-assets/elements/warning-group-square.svg", alt="")
                                img(class="image is-fullwidth is-cover", style="height: 100%", src="images/features/3d-viewer-und-analyse-funktionen-1.png", alt="QWC 3D viewer screenshot")

                        div(class="column is-12 is-5-desktop")
                            div(class="has-mw-md-desktop mx-auto")
                                h3(class="mb-14 title is-size-3 is-spaced") Built to evolve
                                div(class="mb-6 is-flex is-align-items-start")
                                    span(class="mr-4")
                                        svg(xmlns="http://www.w3.org/2000/svg", width="24", height="24", viewbox="0 0 24 24", fill="none")
                                            path(d="M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 3 12 3Z", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M8 11.5L11 14.5L17 8.5", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                    div
                                        h6(class="mb-3 has-text-weight-bold is-size-4") First introduced in Switzerland
                                        p(class="subtitle") QWC1 was introduced in Uster in 2009 as an early web GIS solution built around QGIS.

                                div(class="mb-6 is-flex is-align-items-start")
                                    span(class="mr-4")
                                        svg(xmlns="http://www.w3.org/2000/svg", width="24", height="24", viewbox="0 0 24 24", fill="none")
                                            path(d="M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M8 11.5L11 14.5L17 8.5", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                    div
                                        h6(class="mb-3 has-text-weight-bold is-size-4") Modern generation since 2016
                                        p(class="subtitle") QWC2 introduced a modern, responsive interface and a more extensible architecture.

                                div(class="is-flex is-align-items-start")
                                    span(class="mr-4")
                                        svg(xmlns="http://www.w3.org/2000/svg", width="24", height="24", viewbox="0 0 24 24", fill="none")
                                            path(d="M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M8 11.5L11 14.5L17 8.5", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                    div
                                        h6(class="mb-3 has-text-weight-bold is-size-4") Continuously improved
                                        p(class="subtitle") QWC continues to evolve through open source collaboration and professional maintenance.

            section(class="section trust-section")
                div(class="container")
                    div(class="trust-shell")
                        //- TITLE + INTRO
                        div(class="trust-intro has-text-centered")
                            h3(class="title trust-title mb-4") A trusted open source platform
                            p(class="subtitle trust-subtitle")
                                | QWC is built on top of the QGIS ecosystem and combines years of open source development with modern web technologies and professional expertise.

                        //- FEATURES GRID
                        div(class="columns is-multiline is-variable is-6 trust-grid")

                            div(class="column is-12 is-4-desktop")
                                div(class="trust-feature")
                                    h6(class="trust-feature-title") Official QGIS ecosystem
                                    p(class="trust-feature-copy") Developed within QGIS, ensuring long-term compatibility and stability.

                            div(class="column is-12 is-4-desktop")
                                div(class="trust-feature")
                                    h6(class="trust-feature-title") Proven track record
                                    p(class="trust-feature-copy") First introduced in Switzerland in 2009, continuously evolving since then.

                            div(class="column is-12 is-4-desktop")
                                div(class="trust-feature")
                                    h6(class="trust-feature-title") Modern technologies
                                    p(class="trust-feature-copy") Built with ReactJS and OpenLayers for performance and flexibility.

                            div(class="column is-12 is-4-desktop")
                                div(class="trust-feature")
                                    h6(class="trust-feature-title") Designed for usability
                                    p(class="trust-feature-copy") A clean and responsive interface focused on real workflows.

