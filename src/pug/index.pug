style.
  .hero-qwc {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 16% 18%, rgba(147, 176, 35, 0.14) 0%, rgba(147, 176, 35, 0) 28%),
      radial-gradient(circle at 84% 20%, rgba(37, 150, 190, 0.10) 0%, rgba(37, 150, 190, 0) 26%),
      linear-gradient(135deg, #f5f8f5 0%, #edf4ef 48%, #eef5f7 100%);
    min-height: 58vh;
    display: flex;
    align-items: stretch;
  }

  .hero-qwc::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 78% 24%, rgba(88, 150, 50, 0.08) 0%, rgba(88, 150, 50, 0) 22%),
      linear-gradient(180deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0) 100%);
    pointer-events: none;
  }

  .hero-qwc-section {
    width: 100%;
    display: flex;
    align-items: center;
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
  }

  .hero-qwc-container {
    width: min(1560px, calc(100% - 1rem));
  }

  .hero-qwc-columns {
    min-height: calc(58vh - 5rem);
    align-items: center;
  }

  .hero-qwc-columns > .column:first-child {
    padding-right: 3rem;
  }

  .hero-qwc-columns > .column:last-child {
    padding-left: 2.5rem;
  }

  .hero-qwc-columns > .column:first-child {
    position: relative;
    z-index: 3;
  }

  .hero-qwc-columns > .column:last-child {
    position: relative;
    z-index: 2;
  }

  .partner-logos-row {
    flex-wrap: wrap;
  }

  .partner-logo-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .partner-logo {
    height: 68px;
    width: auto;
    max-width: 240px;
    object-fit: contain;
    display: block;
  }

  @media (min-width: 1024px) {
    .partner-logo-wrap::after {
      content: attr(data-partner);
      position: absolute;
      left: 50%;
      bottom: calc(100% + 10px);
      transform: translateX(-50%) translateY(4px);
      background: #93b023;
      color: #ffffff;
      font-size: 0.78rem;
      font-weight: 600;
      line-height: 1;
      white-space: nowrap;
      padding: 0.5rem 0.7rem;
      border-radius: 999px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.18s ease, transform 0.18s ease;
      box-shadow: 0 10px 22px rgba(147, 176, 35, 0.24);
    }

    .partner-logo-wrap:hover::after {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  .hero-glow-top {
    position: absolute;
    top: -140px;
    right: -80px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(147,176,35,0.14) 0%, rgba(147,176,35,0) 70%);
    pointer-events: none;
  }

  .hero-glow-bottom {
    position: absolute;
    bottom: -180px;
    left: -100px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(37,150,190,0.10) 0%, rgba(37,150,190,0) 72%);
    pointer-events: none;
  }

  .hero-copy {
    max-width: 48rem;
    padding-top: 0;
  }

  .hero-title {
    font-size: clamp(3.5rem, 4.4vw, 5.2rem);
    line-height: 0.92;
    letter-spacing: -0.045em;
    color: #132321;
    white-space: nowrap;
    margin-bottom: 1.8rem !important;
  }

  .hero-subtitle {
    font-size: 1.24rem;
    line-height: 1.48;
    color: #55706a;
    max-width: 38rem;
    margin-left: 0.45rem;
    margin-bottom: 5rem !important;
  }

  .hero-pill-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    min-height: 1.9rem;
    padding: 0.28rem 0.72rem;
    border-radius: 999px;
    border: 1px solid rgba(19, 35, 33, 0.10);
    background: rgba(255,255,255,0.48);
    color: #5d726e;
    font-size: 0.78rem;
    font-weight: 600;
    backdrop-filter: blur(6px);
  }

  .hero-buttons {
    gap: 0.9rem;
    margin-bottom: 0 !important;
  }

  .hero-button-primary,
  .hero-button-secondary {
    min-height: 3.35rem;
    border-radius: 15px;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
    font-weight: 700;
    box-shadow: 0 12px 26px rgba(19,35,33,0.08);
    transition: border-color 0.28s ease, box-shadow 0.28s ease, transform 0.28s ease, background-color 0.28s ease;
  }

  .hero-button-primary {
    background: #589632;
    border-color: #589632;
  }

  .hero-button-primary:hover {
    background: #4f872d;
    border-color: #4f872d;
  }

  .hero-button-secondary {
    border: 1px solid #dbe5e1;
    background: rgba(255,255,255,0.86);
    color: #17302c;
  }

  .hero-button-demo {
    border-color: rgba(147, 176, 35, 0.4);
    box-shadow: 0 0 0 1px rgba(147, 176, 35, 0.18), 0 12px 26px rgba(19,35,33,0.08);
  }

  .hero-button-demo:hover,
  .hero-button-demo:focus-visible {
    border-color: #93b023;
    background: rgba(255,255,255,0.96);
    box-shadow: 0 0 0 4px rgba(147, 176, 35, 0.16), 0 0 24px rgba(147, 176, 35, 0.28), 0 16px 34px rgba(19,35,33,0.12);
    transform: translateY(-1px);
  }

  .hero-visual-wrap {
    position: relative;
    max-width: 520px;
    margin-left: auto;
    margin-right: 0;
    padding-left: 0;
  }

  .hero-shadow {
    position: absolute;
    inset: auto 14% -18px 14%;
    height: 34px;
    background: rgba(8,28,24,0.16);
    filter: blur(24px);
    border-radius: 999px;
  }

  .hero-card {
    position: relative;
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(215,225,221,0.9);
    border-radius: 28px;
    padding: 0.9rem;
    box-shadow: 0 24px 64px rgba(0,0,0,0.12);
  }

  .hero-card-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.55rem;
    padding: 0.2rem 0.35rem 0 0.35rem;
  }

  .hero-card-dots {
    display: flex;
    gap: 0.45rem;
  }

  .hero-card-dots span:nth-child(1),
  .hero-card-dots span:nth-child(2),
  .hero-card-dots span:nth-child(3) {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .hero-card-dots span:nth-child(1) { background: #ff6b6b; }
  .hero-card-dots span:nth-child(2) { background: #ffd166; }
  .hero-card-dots span:nth-child(3) { background: #06d6a0; }

  .hero-card-label {
    font-size: 0.8rem;
    color: #617472;
    font-weight: 600;
  }

  .hero-image-wrap {
    border-radius: 20px;
    overflow: hidden;
    background: #dfe8e4;
    box-shadow: inset 0 0 0 1px rgba(19,35,33,0.05);
  }

  .trust-section {
    padding-top: 5.5rem;
    padding-bottom: 4.5rem;
  }

  .trust-shell {
    max-width: 1080px;
    margin: 0 auto;
  }

  .trust-intro {
    max-width: 760px;
    margin: 0 auto 2.5rem auto;
  }

  .trust-title {
    letter-spacing: -0.03em;
    margin-bottom: 1rem !important;
  }

  .trust-subtitle {
    color: #5f7170;
    line-height: 1.75;
    max-width: 44rem;
    margin: 0 auto;
  }

  .trust-grid {
    margin-top: 0.5rem !important;
    row-gap: 1.25rem;
  }

  .trust-feature {
    padding: 0.75rem 0.5rem;
  }

  .trust-feature-title {
    font-size: 1.45rem;
    line-height: 1.25;
    font-weight: 700;
    color: #10211f;
    margin-bottom: 0.85rem;
  }

  .trust-feature-copy {
    font-size: 1.05rem;
    line-height: 1.9;
