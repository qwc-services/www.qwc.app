mixin main-feature(title, text)
    div(class="is-flex is-align-items-start")
        span(class="mr-4")
            svg(xmlns="http://www.w3.org/2000/svg", width="24", height="24", viewbox="0 0 24 24", fill="none")
                path(d="M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                path(d="M8 11.5L11 14.5L17 8.5", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
        div
            h6(class="mb-3 has-text-weight-bold is-size-4")=title
            p(class="subtitle")=text
            p

mixin trust-feature(title, text)
    div(class="column is-12 is-4-desktop")
        div(class="trust-feature")
            h6(class="trust-feature-title")=title
            p(class="trust-feature-copy")=text

doctype html
html(lang="en")
    head
        title QWC - QGIS Webclient
        include includes/head.pug
    body
        div#front-page
            nav(class="navbar site-navbar has-background-transparent py-5 is-relative")
                div(class="container is-fluid")
                    include includes/navbar-logo.pug
                    div(class="navbar-menu")
                        div(class="navbar-end")
                            include includes/menu.pug

            section(class="hero-qwc")
                div(class="hero-glow-top")
                div(class="hero-glow-bottom")

                div(class="section hero-qwc-section")
                    div(class="container hero-qwc-container")
                        div(class="hero-qwc-columns is-vcentered columns is-multiline is-variable is-8")
                            div(class="column is-12 is-7-desktop mb-20 mb-0-desktop")
                                div(class="hero-copy has-mw-md-desktop")
                                    h1(class="title hero-title mb-5")
                                        | QGIS Web Client

                                    p(class="subtitle hero-subtitle mb-5")
                                        | Modern Web GIS, built on QGIS

                                    div(class="buttons hero-buttons")
                                        a(class="button is-primary is-medium is-rounded hero-button-primary", href="features.html") Explore Features
                                        a(class="button is-light is-medium is-rounded hero-button-secondary hero-button-demo", href="https://qwc2.sourcepole.ch") Open Demo

                            div(class="column is-12 is-5-desktop")
                                div(class="hero-visual-wrap")
                                    img(class="image is-fullwidth", src="images/screens-responsive.png", alt="QWC web map interface")
                            //-
                                div(class="column is-12 is-5-desktop")
                                    div(class="hero-visual-wrap")
                                        div(class="hero-shadow")
                                        div(class="hero-card")
                                            div(class="hero-card-topbar")
                                                div(class="hero-card-dots")
                                                    span
                                                    span
                                                    span
                                                div(class="hero-card-label") QWC Map Viewer

                                            div(class="hero-image-wrap")
                                                img(class="image is-fullwidth", src="images/screens-responsive.png", alt="QWC web map interface")

                div(class="is-hidden navbar-side is-fixed is-top-0 is-bottom-0 is-left-0 has-mw-sm", style="width: 75%; z-index: 9999;")
                    div(class="navbar-backdrop is-fixed is-inset-0 has-background-primary", style="opacity: 90%;")
                    nav(class="navbar is-light is-relative is-flex is-flex-direction-column px-6 py-6 has-background-white", style="width: 100%; height: 100%; overflow-y: auto")
                        include includes/hamburger-logo.pug
                        div
                            div(class="is-flex-direction-column")
                                include includes/menu.pug

            section(class="section")
                div(class="container")
                    div(class="columns is-multiline is-variable is-6")
                        div(class="column is-12 is-5-desktop mb-10 mb-0-desktop")
                            div(class="has-mw-md-desktop")
                                span(class="tag is-warning") Why QWC
                                h3(class="my-6 title is-size-3 is-spaced") Bringing QGIS to the web
                                p(class="has-mw-sm-desktop subtitle")
                                    | QWC is an open source web GIS platform bringing QGIS functionality to the web, combining usability, extensibility and modern web technologies.

                        div(class="column is-12 is-7-desktop")
                            div(class="columns is-multiline")
                                div(class="column is-12 is-6-desktop mb-10")
                                    span
                                        svg(xmlns="http://www.w3.org/2000/svg", width="48", height="48", viewbox="0 0 48 48", fill="none")
                                            path(d="M14 40H40", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M8 40V34L34 8L40 14L14 40H8Z", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M34 20L28 14", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                    h6(class="mt-8 mb-4 is-size-4") Native QGIS support
                                    p(class="subtitle") Full support of cartographic QGIS features and extended functionality.

                                div(class="column is-12 is-6-desktop mb-10")
                                    span
                                        svg(xmlns="http://www.w3.org/2000/svg", width="48", height="48", viewbox="0 0 48 48", fill="none")
                                            path(d="M8 14L24 6L40 14V34L24 42L8 34V14Z", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M30 18L18 30", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M18 18L30 30", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                    h6(class="mt-8 mb-4 is-size-4") Modern Responsive UI
                                    p(class="subtitle") A clean and responsive interface designed for desktop and mobile use.

                                div(class="column is-12 is-6-desktop mb-10 mb-0-desktop")
                                    span
                                        svg(xmlns="http://www.w3.org/2000/svg", width="48", height="48", viewbox="0 0 48 48", fill="none")
                                            path(d="M24 44C24 44 40 36 40 24V10L24 4L8 10V24C8 36 24 44 24 44Z", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M16 23L22 29L34 17", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                    h6(class="mt-8 mb-4 is-size-4") Advanced functionality
                                    p(class="subtitle") Advanced editing tools in 2D and 3D, full-text search, printing and more.

                                div(class="column is-12 is-6-desktop")
                                    span
                                        svg(xmlns="http://www.w3.org/2000/svg", width="48", height="48", viewbox="0 0 48 48", fill="none")
                                            path(d="M24 30C27.866 30 31 26.866 31 23C31 19.134 27.866 16 24 16C20.134 16 17 19.134 17 23C17 26.866 20.134 30 24 30Z", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M42 23.9999C42.006 28.6858 40.1784 33.1881 36.908 36.5439C35.2324 38.2727 33.2261 39.6466 31.0086 40.5839C28.791 41.5213 26.4075 42.0028 24 41.9999C21.5925 42.0028 19.209 41.5213 16.9914 40.5839C14.7739 39.6466 12.7676 38.2727 11.092 36.5439C9.03644 34.4289 7.53208 31.8412 6.71122 29.0085C5.89036 26.1757 5.77815 23.1846 6.38447 20.2982C6.99079 17.4119 8.29705 14.7188 10.1884 12.4557C12.0797 10.1927 14.4981 8.42905 17.2309 7.31994C19.9638 6.21082 22.9273 5.79021 25.8608 6.0951C28.7943 6.39999 31.608 7.42105 34.0543 9.06846C36.5006 10.7159 38.5047 12.9392 39.8902 15.5428C41.2757 18.1464 42.0002 21.0506 42 23.9999V23.9999Z", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                            path(d="M11.092 36.544C12.5768 34.5144 14.5197 32.8639 16.7626 31.7268C19.0056 30.5897 21.4853 29.9981 24 30C26.5147 29.9981 28.9944 30.5897 31.2374 31.7268C33.4803 32.8639 35.4232 34.5144 36.908 36.544", stroke="#006251", stroke-width="2", stroke-linecap="round", stroke-linejoin="round")
                                    h6(class="mt-8 mb-4 is-size-4") Plugin Architecture
                                    p(class="subtitle") Easy to adapt and extend through a modular plugin system.

            section(class="section")
                div(class="container")
                    div(class="is-vcentered columns is-multiline is-variable is-6")
                        div(class="column is-12 is-7-desktop mb-10 mb-0-desktop")
                            div(class="has-mw-md-desktop is-relative")
                                img(class="is-absolute is-block-widescreen is-hidden-touch is-bottom-0 is-left-0", style="width: 160px; height: 160px; margin-left: -80px; z-index: 1;", src="cronos-assets/elements/light-squares.svg", alt="")
                                img(class="ml-20 is-absolute is-block-widescreen is-hidden-touch is-top-0 is-right-0", style="width: 160px; height: 160px; margin-right: -80px; z-index: 1;", src="cronos-assets/elements/warning-group-square.svg", alt="")
                                img(class="image is-fullwidth is-cover", style="height: 100%", src="images/features/3d-viewer-und-analyse-funktionen-1.png", alt="QWC 3D viewer screenshot")

                        div(class="column is-12 is-5-desktop")
                            div(class="has-mw-md-desktop mx-auto")
                                h3(class="mb-14 title is-size-3 is-spaced") Modern architecture

                                +main-feature("Micro services", "Backend services for editing, search, etc. based on flexible and extensible micro service architecture.")

                                +main-feature("Best-in-class frontend technology", "Based on ReactJS, OpenLayers and ThreeJS for advanced 2D and 3D mapping.")

                                +main-feature("Extension API", "Plugin system for custom extensions with extensive JavaScript and WebSocket APIs.")

            section(class="section trust-section")
                div(class="container")
                    div(class="trust-shell")
                        //- TITLE + INTRO
                        div(class="trust-intro has-text-centered")
                            h3(class="title trust-title mb-4") A trusted open source platform
                            p(class="subtitle trust-subtitle")
                                | QWC is built on top of the QGIS ecosystem and combines years of open source development with modern web technologies and professional expertise.

                        //- FEATURES GRID
                        div(class="columns is-multiline is-variable is-6 trust-grid")

                            +trust-feature("Part of QGIS ecosystem", "Developed within QGIS organisation, ensuring long-term compatibility and stability.")

                            +trust-feature("Scalability", "Scale from single server setup to Kubernetes deployment.")

                            +trust-feature("Multitenant setup", "Provide customized frontends for multiple users and organizations.")

                            +trust-feature("Enterprise ready", "Role based access control (RBAC) and Single Sign On (SSO) support.")

                            +trust-feature("Extensible architecture", "Plugin-based system for easy customization and extension.")

                            +trust-feature("Open source", "Developed openly with contributions from an international community.")

                        //- PARTNERS LOGOS
                        div(class="trust-partners")

                            div(class="has-text-centered trust-partners-head")
                                p(class="trust-partners-label") Trusted by organizations and partners

                            //- 🔹 ROW 1
                            div(class="is-flex is-justify-content-center is-align-items-center partner-logos-row trust-partner-row")
                                div(class="partner-logo-wrap", data-partner="City of Zürich")
                                    img(class="partner-logo", src="images/logos/sz.png" alt="Stadt Zürich", style="height: 50px; width: auto;")
                                div(class="partner-logo-wrap", data-partner="City of Frankfurt")
                                    img(class="partner-logo", src="images/logos/sfr.png" alt="Stadt Frankfurt", style="height: 50px; width: auto;")
                                div(class="partner-logo-wrap", data-partner="Berliner Verkehrsbetriebe")
                                    img(class="partner-logo", src="images/logos/bvb.svg" alt="Berliner Verkehrsbetriebe", style="height: 50px; width: auto;")
                                div(class="partner-logo-wrap", data-partner="University of Zurich")
                                    img(class="partner-logo", src="images/logos/uzh.png" alt="Universität Zürich", style="height: 50px; width: auto;")

                            //- 🔹 ROW 2
                            div(class="is-flex is-justify-content-center is-align-items-center partner-logos-row trust-partner-row trust-partner-row-bottom")
                                div(class="partner-logo-wrap", data-partner="Canton of Glarus")
                                    img(class="partner-logo", src="images/logos/gl.png" alt="Canton of Glarus", style="height: 50px; width: auto;")
                                div(class="partner-logo-wrap", data-partner="Canton of Solothurn")
                                    img(class="partner-logo", src="images/logos/so.png" alt="Canton of Solothurn", style="height: 50px; width: auto;")
                                div(class="partner-logo-wrap", data-partner="Stadtwerke Lemgo")
                                    img(class="partner-logo", src="images/logos/lemgo.png" alt="Stadtwerke Lemgo", style="height: 50px; width: auto;")
                                div(class="partner-logo-wrap", data-partner="City of Wolfsburg")
                                    img(class="partner-logo", src="images/logos/wolfsburg.jpg" alt="Stadt Wolfsburg", style="height: 50px; width: auto;")
                                div(class="partner-logo-wrap", data-partner="City of Jena")
                                    img(class="partner-logo", src="images/logos/jena.svg" alt="Stadt Jena", style="height: 50px; width: auto;")

            section(class="section")
                include includes/footer.pug
